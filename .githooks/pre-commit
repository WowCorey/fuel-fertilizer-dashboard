#!/usr/bin/env bash
set -euo pipefail

python_cmd=""
if [ -x ".venv/Scripts/python.exe" ]; then
  python_cmd=".venv/Scripts/python.exe"
elif [ -x ".venv/bin/python" ]; then
  python_cmd=".venv/bin/python"
elif command -v python3 >/dev/null 2>&1; then
  python_cmd="python3"
elif command -v python >/dev/null 2>&1; then
  python_cmd="python"
else
  echo "[X] Python not found. Cannot run pre-commit checks."
  exit 1
fi

# Enforce small, targeted commits unless explicitly overridden.
"$python_cmd" scripts/check_commit_scope.py
